# AI Visibility Analyzer - Environment Variables
# Copy to .env.local for development

# ─── Rate Limiting ──────────────────────────────────────────────
# Max requests per IP per window
RATE_LIMIT_MAX=10
# Window duration in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# ─── App Config ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://asksarah.ai
NEXT_PUBLIC_APP_NAME=AI Visibility Analyzer

# ─── GEO GPT ────────────────────────────────────────────────────
NEXT_PUBLIC_GEO_GPT_URL=https://chatgpt.com/g/g-6904a060fd8c8191bf5cdbc82571fee9-ai-visibility-engine-geo

# ─── Optional: Analytics ────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── No API keys needed! ────────────────────────────────────────
# This tool uses:
# - Cheerio for HTML scraping (no API key)
# - Google cache checks via fetch (no API key)
# - Heuristic scoring (no API key)
# - Estimated domain authority (no Moz needed)
